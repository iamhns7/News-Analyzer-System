generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Source {
  id         Int       @id @default(autoincrement())
  name       String
  url        String
  rssUrl     String?
  trustScore Int       @default(100)
  articles   Article[]
}

model Article {
  id              Int       @id @default(autoincrement())
  sourceId        Int
  title           String
  originalContent String
  url             String    @unique
  publishedAt     DateTime
  category        String?
  sourceName      String?
  sourceType      String    @default("API")
  analysis        Analysis?
  source          Source    @relation(fields: [sourceId], references: [id])
}

model Analysis {
  id             Int     @id @default(autoincrement())
  articleId      Int     @unique
  aiSummary      String
  isFake         Boolean @default(false)
  fakeNewsReason String?
  article        Article @relation(fields: [articleId], references: [id])
}
